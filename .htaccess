<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Force HTTPS (non-HTTPS → HTTPS, preserving www if present)
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,NE,R=301]

    # 2. Force WWW (https://sseventsdfw.com → https://www.sseventsdfw.com)
    RewriteCond %{HTTP_HOST} !^www\. [NC]
    RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,NE,R=301]

    # 3. Route to public/ folder (for shared hosting / cPanel)
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
